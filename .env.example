# Frontend environment variables (Vite). Copy to .env and adjust as needed.

# API origin used in PRODUCTION builds. In dev, the Vite proxy (/api -> 127.0.0.1:8000) is used instead.
VITE_API_BASE=http://127.0.0.1:8000/api

# WhatsApp contact number, digits only in international format (no leading +).
VITE_WHATSAPP_NUMBER=994000000000
