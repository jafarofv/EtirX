DJANGO_DEBUG=True
DJANGO_SECRET_KEY=change-me-to-a-random-50-char-string
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DJANGO_CSRF_TRUSTED_ORIGINS=https://etirx.az
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_SSL_REDIRECT=False

# Redis (optional for dev – uses SQLite + local cache if not set)
REDIS_URL=redis://127.0.0.1:6379/0

# Email (SMTP)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-password
DEFAULT_FROM_EMAIL=noreply@etirx.az

# Twilio WhatsApp (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# PostgreSQL (optional – defaults to SQLite)
# DATABASE_URL=postgres://user:password@localhost:5432/etirx
